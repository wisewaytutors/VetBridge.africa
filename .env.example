# ─── DATABASE ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://vetbridge_user:password@localhost:5432/vetbridge_db"

# ─── REDIS ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── SERVER ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL="http://localhost:19006"

# ─── OTP ──────────────────────────────────────────────────────────────────────
OTP_EXPIRES_MINUTES=10

# ─── SMS (AfricasTalking — Ethiopia) ──────────────────────────────────────────
AT_API_KEY="your-africas-talking-api-key"
AT_USERNAME="sandbox"
AT_SENDER_ID="VetBridge"

# ─── TELEBIRR ─────────────────────────────────────────────────────────────────
TELEBIRR_APP_ID="your-telebirr-app-id"
TELEBIRR_APP_KEY="your-telebirr-app-key"
TELEBIRR_PUBLIC_KEY="your-telebirr-public-key"
TELEBIRR_BASE_URL="https://api.ethiotelecom.et/teleBirr"
TELEBIRR_NOTIFY_URL="https://api.vetbridge.et/payments/telebirr/webhook"

# ─── CBE BIRR ─────────────────────────────────────────────────────────────────
CBE_API_KEY="your-cbe-api-key"
CBE_MERCHANT_ID="your-cbe-merchant-id"
CBE_BASE_URL="https://cbebirr.com/api"
CBE_CALLBACK_URL="https://api.vetbridge.et/payments/cbe/webhook"

# ─── CLOUDFLARE R2 ────────────────────────────────────────────────────────────
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="vetbridge-uploads"
R2_PUBLIC_URL="https://files.vetbridge.et"

# ─── FIREBASE FCM ─────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID="vetbridge-app"
FIREBASE_PRIVATE_KEY="your-firebase-private-key"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@vetbridge-app.iam.gserviceaccount.com"

# ─── CLAUDE AI ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="your-anthropic-api-key"

# ─── GOOGLE MAPS ──────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# ─── PLATFORM CONFIG ──────────────────────────────────────────────────────────
PLATFORM_NAME="VetBridge"
PLATFORM_EMAIL="support@vetbridge.et"
PLATFORM_DOMAIN="vetbridge.et"
DEFAULT_COMMISSION_RATE=0.15
ESCROW_RELEASE_DELAY_HOURS=1
LEAKAGE_CHECK_CRON="0 2 * * *"
REMINDER_CRON="0 8 * * *"
